// packages/database/prisma/schema.prisma

// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------
// 1. USER & BILLING
// ------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  role          Role      @default(USER)
  isVerified    Boolean   @default(false)
  
  otpCode       String?   
  otpExpiresAt  DateTime? 

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  wallet        Wallet?
  settings      UserSettings?
  contentJobs   ContentJob[]
  
  transactions  Transaction[]

  brandProfile  BrandProfile?
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  amount      Int      // Negative for usage (e.g., -5), positive for top-up
  type        String   // "RESEARCH", "GENERATION", "EDIT", "PROOFREAD", "TOPUP"
  description String?  // Optional: "Article: How to bake a cake"
  createdAt   DateTime @default(now())

  @@index([userId])
}

model Wallet {
  id               String   @id @default(cuid())
  userId           String   @unique
  creditsAvailable Int      @default(0)
  
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  USER
  ADMIN
}

// ------------------------------------------------------
// 2. MODULAR TOOLS & JOBS
// ------------------------------------------------------

model Tool {
  id          String   @id @default(cuid())
  slug        String   @unique // e.g., "seo-writer", "ad-copy"
  name        String   
  isActive    Boolean  @default(true)
  
  jobs        ContentJob[]
}

model ContentJob {
  id            String   @id @default(cuid())
  userId        String
  toolId        String
  aiModel       AIModel  @default(CLAUDE_3_5_SONNET) // Default best model
  status        JobStatus @default(PENDING)
  
  inputPayload  Json     // User input data (keyword, language, etc.)
  outputContent String?  // Final generated HTML/Markdown
  seoMetadata   Json?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tool          Tool     @relation(fields: [toolId], references: [id])
}

enum AIModel {
  CLAUDE_3_5_SONNET
  GPT_4_OMNI
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ------------------------------------------------------
// 3. i18n TRANSLATIONS
// ------------------------------------------------------

model Translation {
  id          String   @id @default(cuid())
  key         String   @unique // e.g., "auth.login.button"
  enUS        String   // Primary language
  trTR        String?  // Secondary language
}

// ------------------------------------------------------
// 4. USER SETTINGS
// ------------------------------------------------------

model UserSettings {
  id            String   @id @default(cuid())
  userId        String   @unique
  wpUrl         String?
  wpUsername    String?
  wpAppPassword String?
  wpSitemap     String?
  defaultStatus String   @default("draft")

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BrandProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  name        String
  description String   @db.Text
  sitemapUrl  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}