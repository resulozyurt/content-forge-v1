// packages/database/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------
// 1. USER & BILLING
// ------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  role          Role      @default(USER)
  isVerified    Boolean   @default(false)
  
  otpCode       String?   
  otpExpiresAt  DateTime? 

  // --- NEW: User Profile Fields ---
  name             String?
  image            String?   @db.Text
  phone            String?
  jobTitle         String?
  company          String?
  industry         String?
  timezone         String?
  language         String    @default("tr")
  marketingConsent Boolean   @default(false)
  // --------------------------------

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  wallet        Wallet?
  settings      UserSettings?
  contentJobs   ContentJob[]
  
  transactions  Transaction[]

  brandProfile  BrandProfile?
  
  // NEW: Relation to store keyword analysis sessions (Bugün eklediğimiz modül)
  keywordSessions KeywordSession[]
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  amount      Int      // Negative for usage (e.g., -5), positive for top-up
  type        String   // "RESEARCH", "GENERATION", "EDIT", "PROOFREAD", "TOPUP"
  description String?  // Optional: "Article: How to bake a cake"
  createdAt   DateTime @default(now())

  @@index([userId])
}

model Wallet {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id])
  creditsAvailable Int      @default(0)
  updatedAt        DateTime @updatedAt
}

enum Role {
  USER
  ADMIN
}

// ------------------------------------------------------
// 2. CONTENT GENERATION
// ------------------------------------------------------

model Tool {
  id          String       @id @default(cuid())
  name        String       @unique // e.g., "Article Generator"
  slug        String       @unique // e.g., "article-generator"
  description String?
  price       Int          @default(1)
  isActive    Boolean      @default(true)
  contentJobs ContentJob[]
}

model ContentJob {
  id            String     @id @default(cuid())
  userId        String
  toolId        String
  status        JobStatus  @default(PENDING)
  
  inputPayload  Json       
  outputContent String?    
  seoMetadata   Json?
  aiModel       AIModel?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tool          Tool     @relation(fields: [toolId], references: [id])
}

enum AIModel {
  CLAUDE_3_5_SONNET
  GPT_4_OMNI
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ------------------------------------------------------
// 3. i18n TRANSLATIONS
// ------------------------------------------------------

model Translation {
  id          String   @id @default(cuid())
  key         String   @unique // e.g., "auth.login.button"
  enUS        String   // Primary language
  trTR        String?  // Secondary language
}

// ------------------------------------------------------
// 4. USER SETTINGS
// ------------------------------------------------------

model UserSettings {
  id            String   @id @default(cuid())
  userId        String   @unique
  wpUrl         String?
  wpUsername    String?
  wpAppPassword String?
  wpSitemap     String?
  defaultStatus String   @default("draft")

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BrandProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  name        String
  description String   @db.Text
  sitemapUrl  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ------------------------------------------------------
// 5. KEYWORD LAB
// ------------------------------------------------------

model KeywordSession {
  id          String   @id @default(cuid())
  userId      String
  seedKeyword String
  results     Json     // Full Claude output — all categories
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}